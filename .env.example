# SEC requires all EDGAR clients to identify themselves via User-Agent.
# Format: "Name email@example.com"
SEC_USER_AGENT="Your Name (you@example.com)"

# Resend API key for email alerts. Get one at https://resend.com.
# If unset, emails are skipped (dashboard still generates, other alerts still fire).
RESEND_API_KEY=

# Must be a verified sender on your Resend account.
ALERT_EMAIL_FROM="alerts@yourdomain.com"

# Where to send alerts.
ALERT_EMAIL_TO="you@example.com"
